# =====================================================
# Battle XI · Variables de entorno
# Copiá este archivo a .env.local y completá los valores
# =====================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---- Replicate (IA generativa para transformar figuritas) ----
# Sacá tu token en https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Modelo recomendado (Flux Schnell · rápido y barato)
REPLICATE_MODEL=black-forest-labs/flux-schnell

# ---- Cloudinary (storage de imágenes generadas) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Database (Postgres en Railway) ----
DATABASE_URL=postgresql://user:password@host:5432/battlexi

# ---- Auth (sesiones) ----
AUTH_SECRET=
# Generá uno con: openssl rand -base64 32

# ---- Google Vision (opcional, si querés mejor OCR que Tesseract) ----
GOOGLE_VISION_API_KEY=

# ---- Telemetría (opcional) ----
NEXT_TELEMETRY_DISABLED=1
